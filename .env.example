# API Keys for A2A Lab
# Copy this file to .env and fill in your API keys
# You need an Anthropic API key for the agents

# Anthropic (Required - used by strands-agents via litellm)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=


# Braintrust (Observability)
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=project_name:dsan6725

# Registry URL (stub registry running locally - no changes needed)
MCP_REGISTRY_URL=http://127.0.0.1:7861
